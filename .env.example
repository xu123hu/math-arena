# ==================== Math Arena 开发环境变量 ====================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# -------------------- 数据库 --------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/math_arena

# -------------------- Redis --------------------
REDIS_URL=redis://localhost:6379/0

# -------------------- 星火大模型（主通道） --------------------
# 注意：必须使用 HTTP 协议，禁止 WebSocket SDK
SPARK_API_PASSWORD=your_spark_api_password_here
SPARK_MODEL=spark-ultra

# -------------------- DeepSeek（备用通道） --------------------
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-v4-flash
# 聊天场景默认关闭思考模式（ADR-001-8）
DEEPSEEK_THINKING=false

# -------------------- Embedding / Reranker --------------------
EMBEDDING_BASE_URL=http://localhost:8080
RERANKER_BASE_URL=http://localhost:8081

# -------------------- JWT --------------------
JWT_SECRET=change-me-to-a-random-secret-in-production

# -------------------- 应用 --------------------
# 前端 VITE 环境变量（前端使用）
VITE_API_BASE=http://localhost:8000/api

# 短信验证码（开发环境固定 123456）
DEV_SMS_CODE=123456
